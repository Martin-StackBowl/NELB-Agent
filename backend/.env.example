# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname

# Azure AI Foundry
AZURE_AI_FOUNDRY_ENDPOINT=https://your-project-resource.services.ai.azure.com/
AZURE_AI_FOUNDRY_API_KEY=your-key-here
AZURE_AI_FOUNDRY_DEPLOYMENT=o4-mini
AZURE_AI_FOUNDRY_API_VERSION=2025-04-01-preview

# Azure Maps
AZURE_MAPS_KEY=your-azure-maps-key

# Azure AI Search (Foundry IQ knowledge base)
AZURE_SEARCH_ENDPOINT=https://nelb-search.search.windows.net
AZURE_SEARCH_KEY=your-search-admin-key
AZURE_SEARCH_KNOWLEDGE_BASE=nelb-work-guides

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# App config
APP_ENV=development
DEFAULT_RADIUS_KM=5
FAIRNESS_THRESHOLD_JOBS=3
FAIRNESS_WINDOW_DAYS=7
MAX_RECOMMENDATIONS=5
